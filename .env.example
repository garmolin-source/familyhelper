# WhatsApp groups to monitor (comma-separated, partial match)
MONITORED_GROUPS=כיתה א,גן חובה,כדורגל

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary   # or a shared calendar ID

# Email confirmation (Gmail App Password)
EMAIL_FROM=your@gmail.com
EMAIL_TO=or@gmail.com,husband@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx   # Gmail App Password, NOT your real password

# Server
PORT=3000
